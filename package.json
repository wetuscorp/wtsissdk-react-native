{
  "name": "@wetusco/wts-sdk",
  "version": "0.1.0-alpha.1",
  "description": "Official wts.is deep-link and attribution SDK for React Native",
  "license": "Apache-2.0",
  "homepage": "https://wts.is",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wetuscorp/wtsissdk-react-native.git"
  },
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android/build.gradle",
    "android/src",
    "ios/WtsSdk.h",
    "ios/WtsSdk.mm",
    "ios/WtsSdkNativeCore.swift",
    "LICENSE",
    "WtsSdkReactNative.podspec"
  ],
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "scripts": {
    "build": "bob build",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "contracts:verify": "node scripts/verify-contracts.mjs",
    "pack:check": "node scripts/verify-package.mjs"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/react": "latest",
    "jest": "^29.7.0",
    "react": "latest",
    "react-native": "0.86.0",
    "react-native-builder-bob": "latest",
    "ts-jest": "^29.2.6",
    "typescript": "latest"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": ">=0.85 <0.87"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/",
      "/example/"
    ]
  },
  "codegenConfig": {
    "name": "WtsSdkSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "co.wetus.sdk.reactnative"
    },
    "ios": {
      "modulesProvider": {
        "WtsSdk": "WtsSdk"
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      "module",
      "typescript"
    ]
  }
}
