{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wts.is/schemas/sdk/mobile/v3/event-batch.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "events"],
  "properties": {
    "schemaVersion": { "const": 3 },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "clientEventId",
          "installId",
          "occurredAt",
          "metadata",
          "type",
          "properties"
        ],
        "properties": {
          "schemaVersion": { "const": 3 },
          "clientEventId": { "type": "string", "format": "uuid" },
          "installId": { "type": "string", "minLength": 8, "maxLength": 128 },
          "sessionId": { "type": "string", "minLength": 8, "maxLength": 128 },
          "occurredAt": { "type": "string", "format": "date-time" },
          "metadata": { "$ref": "common.schema.json#/$defs/metadata" },
          "type": { "enum": ["screen_view", "custom"] },
          "eventKey": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
          "screenName": { "type": "string", "minLength": 1, "maxLength": 120 },
          "properties": {
            "type": "object",
            "maxProperties": 20,
            "additionalProperties": { "$ref": "common.schema.json#/$defs/scalar" }
          },
          "linkId": { "type": "string" },
          "revenue": {
            "type": "object",
            "additionalProperties": false,
            "required": ["amount", "currency"],
            "properties": {
              "amount": { "type": "string", "pattern": "^-?\\d{1,12}(?:\\.\\d{1,6})?$" },
              "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "screen_view" } } },
            "then": { "required": ["screenName"], "not": { "required": ["revenue"] } }
          },
          {
            "if": { "properties": { "type": { "const": "custom" } } },
            "then": { "required": ["eventKey"] }
          }
        ]
      }
    }
  }
}
